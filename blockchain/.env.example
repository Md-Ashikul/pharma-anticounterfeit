# ═══════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT CONFIGURATION (Consortium Governance)
# ═══════════════════════════════════════════════════════════════════════════════

# ── Deployer wallet (MetaMask Account 1 — Government Regulator 1) ──────────────
# This account deploys contracts AND is Regulator 1 of the 2-of-3 voting system
# Fund Arbitrum Sepolia via https://faucet.quicknode.com/arbitrum/sepolia
DEPLOYER_PRIVATE_KEY=0xyour_account_1_private_key

# ── RPC endpoints ────────────────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your-key
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# ── Governance Setup (2-of-3 voting) ────────────────────────────────────────
# Regulator 1: 0x... (Account 1 — deployer, will be set automatically)
# Regulator 2: 0x... (Account 2 — MetaMask Account 2)
# Regulator 3: 0x... (Account 3 — MetaMask Account 3)
# Threshold: 2 (any 2 of 3 must approve)

GOVERNANCE_REGULATORS='["0xAccount1Address","0xAccount2Address","0xAccount3Address"]'
GOVERNANCE_THRESHOLD=2

# ── Block explorer API keys (only needed for `hardhat verify`) ───────────────
ETHERSCAN_API_KEY=your_etherscan_key
ARBISCAN_API_KEY=your_arbiscan_key

# ═══════════════════════════════════════════════════════════════════════════════
# REFERENCE: MetaMask Account Setup
# ═══════════════════════════════════════════════════════════════════════════════
# Account 1: Government Regulator (Deployer)
# Account 2: Government Regulator
# Account 3: Government Regulator
# Account 4: Manufacturer
# Account 5: Distributor
# Account 6: Retailer
