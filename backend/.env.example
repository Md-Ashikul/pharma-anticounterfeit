# ════════════════════════════════════════════════════════════════
#  BACKEND (API) ENVIRONMENT — copy to .env and fill in the blanks
# ════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Active network ───────────────────────────────────────────────
# Which chain the running API talks to. "sepolia" (L1, default) or "arbitrum" (L2).
# Flip this single value to point the live app at either network.
ACTIVE_NETWORK=sepolia

# ── RPC endpoints (one per network) ──────────────────────────────
# Free providers: Alchemy, Infura, or the public Arbitrum endpoint.
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# ── Deployed contract addresses — Ethereum Sepolia (L1) ──────────
# Defaults below are the currently deployed addresses (deployed-addresses.json).
GOVERNMENT_REGISTRY_ADDRESS=0xC5714bc15E5a45fB73d72aC4e0774364c5cd9954
MANUFACTURER_BATCH_ADDRESS=0xb6216d0d6FCc97d7CC7Aae797262E1AA339013E2
SUPPLY_CHAIN_TRACKER_ADDRESS=0x91614bFbeC6AD05e37b6c0Dd9d5abadc82e9c2aa

# ── Deployed contract addresses — Arbitrum Sepolia (L2) ──────────
ARBITRUM_GOVERNMENT_REGISTRY_ADDRESS=0xD72A7A156515A5082d8Bc56B05C33Cd2EDaebD7d
ARBITRUM_MANUFACTURER_BATCH_ADDRESS=0x457e47f431EBDa9EfB28F2f05a439CFd01B90Fb1
ARBITRUM_SUPPLY_CHAIN_TRACKER_ADDRESS=0xe805DaD6c993179E0D5605c2c8B90083Bcb390fD

# ── Government / relayer wallet ──────────────────────────────────
# Signs transactions the backend submits on behalf of the consortium
# (e.g. relaying verifyAndBurn). Must be a regulator key. NEVER commit the real value.
GOVERNMENT_PRIVATE_KEY=your_government_wallet_private_key_here

# ── Database ─────────────────────────────────────────────────────
# MongoDB connection string (Atlas free tier works).
MONGODB_URI=mongodb://localhost:27017/pharma-anticounterfeit

# ── IPFS (Pinata) ────────────────────────────────────────────────
# Public gateway used to fetch the Merkle tree JSON during verification.
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ── Frontend URLs (CORS allow-list) ──────────────────────────────
FRONTEND_URL=http://localhost:3000
PWA_URL=http://localhost:3001

# ── SIWE (Sign-In With Ethereum) ─────────────────────────────────
SIWE_DOMAIN=localhost
SIWE_STATEMENT=Sign in to Pharma Anti-Counterfeit System
