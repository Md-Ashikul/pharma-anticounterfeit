# ═══════════════════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
PORT=4000
NODE_ENV=development

# ═══════════════════════════════════════════════════════════════════════════════
# BLOCKCHAIN CONFIGURATION (Arbitrum Sepolia)
# ═══════════════════════════════════════════════════════════════════════════════
ACTIVE_NETWORK=arbitrum
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Contract addresses (from deploy output)
GOVERNMENT_REGISTRY_ADDRESS=0x...deployed_address_here
MANUFACTURER_BATCH_ADDRESS=0x...deployed_address_here
SUPPLY_CHAIN_TRACKER_ADDRESS=0x...deployed_address_here

# ═══════════════════════════════════════════════════════════════════════════════
# GOVERNMENT REGULATORY SETUP (2-of-3 Consortium)
# ═══════════════════════════════════════════════════════════════════════════════
# Account 1 (Deployer, Regulator 1) — THIS key signs blockchain transactions
# NOTE: Only used for fallback direct signing; primary authority via 2-of-3 voting
GOVERNMENT_PRIVATE_KEY=0xaccount_1_private_key

# Account 2 (Regulator 2) — For reference/audit only
GOVERNMENT_REGULATOR_2=0xAccount2Address

# Account 3 (Regulator 3) — For reference/audit only
GOVERNMENT_REGULATOR_3=0xAccount3Address

# ═══════════════════════════════════════════════════════════════════════════════
# ACTOR ACCOUNTS (MetaMask)
# ═══════════════════════════════════════════════════════════════════════════════
MANUFACTURER_ACCOUNT=0xAccount4Address
DISTRIBUTOR_ACCOUNT=0xAccount5Address
RETAILER_ACCOUNT=0xAccount6Address

# ═══════════════════════════════════════════════════════════════════════════════
# IPFS & PINATA
# ═══════════════════════════════════════════════════════════════════════════════
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ═══════════════════════════════════════════════════════════════════════════════
# FRONTEND URLS (CORS)
# ═══════════════════════════════════════════════════════════════════════════════
FRONTEND_URL=http://localhost:3000
PWA_URL=http://localhost:3001

# ═══════════════════════════════════════════════════════════════════════════════
# SIWE (Sign In With Ethereum)
# ═══════════════════════════════════════════════════════════════════════════════
SIWE_DOMAIN=localhost
SIWE_STATEMENT=Sign in to Pharma Anti-Counterfeit System
