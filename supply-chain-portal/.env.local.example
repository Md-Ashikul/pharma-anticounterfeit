NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_HARDHAT_CHAIN_ID=31337

# ── Network toggle (sepolia | arbitrum) ────────────────────────────────────
NEXT_PUBLIC_ACTIVE_NETWORK=sepolia
NEXT_PUBLIC_SEPOLIA_CHAIN_ID=11155111
NEXT_PUBLIC_ARBITRUM_CHAIN_ID=421614

# ── Contract addresses (per network) ───────────────────────────────────────
NEXT_PUBLIC_SUPPLY_CHAIN_TRACKER_ADDRESS=0x...
NEXT_PUBLIC_ARBITRUM_SUPPLY_CHAIN_TRACKER_ADDRESS=0x...

# Required for the consortium governance UI (propose + vote via MetaMask):
NEXT_PUBLIC_GOVERNMENT_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_ARBITRUM_GOVERNMENT_REGISTRY_ADDRESS=0x...

# ── Read-only RPC for governance queries (regulator list + proposal logs) ───
# Optional but recommended — avoids MetaMask getLogs range limits. Falls back
# to the injected MetaMask provider when unset.
NEXT_PUBLIC_SEPOLIA_RPC_URL=
NEXT_PUBLIC_ARBITRUM_RPC_URL=
# Block the GovernmentRegistry was deployed at, to keep log scans fast (optional).
NEXT_PUBLIC_GOV_REGISTRY_DEPLOY_BLOCK=0
