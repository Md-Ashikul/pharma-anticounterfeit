# ════════════════════════════════════════════════════════════════
#  CRYPTO-SERVICE ENVIRONMENT — copy to .env and fill in the blanks
#  Used by: setupRegistry.js, generateBatch.js, benchmark.js
# ════════════════════════════════════════════════════════════════

# ── IPFS (Pinata) ────────────────────────────────────────────────
# Free keys: https://app.pinata.cloud/keys
PINATA_API_KEY=your_pinata_api_key_here
PINATA_API_SECRET=your_pinata_api_secret_here
# Public gateway used by the benchmark to time cold IPFS retrieval.
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ── RPC endpoints (one per network) ──────────────────────────────
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# ── Deployed contract addresses — Ethereum Sepolia (L1) ──────────
# Defaults below match blockchain/deployed-addresses.json.
GOVERNMENT_REGISTRY_ADDRESS=0xC5714bc15E5a45fB73d72aC4e0774364c5cd9954
MANUFACTURER_BATCH_ADDRESS=0xb6216d0d6FCc97d7CC7Aae797262E1AA339013E2
SUPPLY_CHAIN_TRACKER_ADDRESS=0x91614bFbeC6AD05e37b6c0Dd9d5abadc82e9c2aa

# ── Deployed contract addresses — Arbitrum Sepolia (L2) ──────────
ARBITRUM_GOVERNMENT_REGISTRY_ADDRESS=0xD72A7A156515A5082d8Bc56B05C33Cd2EDaebD7d
ARBITRUM_MANUFACTURER_BATCH_ADDRESS=0x457e47f431EBDa9EfB28F2f05a439CFd01B90Fb1
ARBITRUM_SUPPLY_CHAIN_TRACKER_ADDRESS=0xe805DaD6c993179E0D5605c2c8B90083Bcb390fD

# ── Consortium regulator keys (M-of-N governance) ────────────────
# setupRegistry.js registers supply-chain entities via the consortium vote flow,
# using ALL three regulators dynamically:
#   Regulator 1 proposes (auto-votes YES) -> Regulators 2 & 3 cast their votes ->
#   the contract auto-executes the instant YES votes reach the threshold (2-of-3).
# Each REGULATOR_*_PRIVATE_KEY must be a DIFFERENT on-chain regulator address.
# REGULATOR_1 falls back to GOVERNMENT_PRIVATE_KEY if left unset.
REGULATOR_1_PRIVATE_KEY=your_regulator_1_private_key_here
REGULATOR_2_PRIVATE_KEY=your_regulator_2_private_key_here
REGULATOR_3_PRIVATE_KEY=your_regulator_3_private_key_here

# Optional: simulate a dissenting regulator. Default is "yes" for all.
# The proposer (Regulator 1) always votes YES automatically, so its setting
# is effectively ignored. Accepted "no" values: no/false/0/n/reject/nay.
# REGULATOR_1_VOTE=yes
# REGULATOR_2_VOTE=yes
# REGULATOR_3_VOTE=yes

# Optional fallback for REGULATOR_1 if REGULATOR_1_PRIVATE_KEY is unset.
GOVERNMENT_PRIVATE_KEY=your_government_wallet_private_key_here

# ── Manufacturer wallet ──────────────────────────────────────────
# Signs registerBatch / verifyAndBurn in generateBatch.js and benchmark.js.
# Must be whitelisted as a Manufacturer (role 1) via setupRegistry.js first.
MANUFACTURER_PRIVATE_KEY=your_manufacturer_private_key_here

# ── Supply-chain wallet addresses (whitelisted by setupRegistry.js) ──
# Public addresses (NOT private keys) registered as the three roles.
# Role 1 = Manufacturer, 2 = Distributor, 3 = Retailer.
MANUFACTURER_ADDRESS=0xYourManufacturerAddressHere
DISTRIBUTOR_ADDRESS=0xYourDistributorAddressHere
RETAILER_ADDRESS=0xYourRetailerAddressHere

# ── QR code base URL ─────────────────────────────────────────────
# Base URL embedded in the public tracking QR codes.
APP_BASE_URL=http://localhost:3000

# ── Benchmark tunables (optional — benchmark.js) ─────────────────
# BENCH_STRIP_COUNT=64    # leaves in the seeded benchmark batch
# BENCH_GAS_SAMPLES=10    # leaves used for non-destructive estimateGas sampling
# BENCH_REAL_TXS=3        # real verifyAndBurn txs per network (consumes leaves)
