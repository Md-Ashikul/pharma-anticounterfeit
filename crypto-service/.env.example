# Copy this to .env and fill in your Pinata credentials
# Get them free at: https://app.pinata.cloud/keys

PINATA_API_KEY=your_pinata_api_key_here
PINATA_API_SECRET=your_pinata_api_secret_here

# Your deployed contract addresses (from deployed-addresses.json)
GOVERNMENT_REGISTRY_ADDRESS=Account0
MANUFACTURER_BATCH_ADDRESS=Account1
SUPPLY_CHAIN_TRACKER_ADDRESS=Account3
# Hardhat local node RPC
RPC_URL=http://127.0.0.1:8545

# Manufacturer wallet (Account #1 from hardhat node output)
MANUFACTURER_PRIVATE_KEY=MANUFACTURER_PRIVATE_KEY

# Base URL for QR tracking links
APP_BASE_URL=http://localhost:3000

# ─── Arbitrum (L2) — needed by the dual-network benchmark ───────────────────
ARBITRUM_RPC_URL=
ARBITRUM_GOVERNMENT_REGISTRY_ADDRESS=
ARBITRUM_MANUFACTURER_BATCH_ADDRESS=
ARBITRUM_SUPPLY_CHAIN_TRACKER_ADDRESS=

# ─── Benchmark tunables (OPTIONAL — leave unset to use defaults) ─────────────
# These are NOT required. benchmark.js falls back to the defaults shown below.
# BENCH_STRIP_COUNT=64   # leaves in the seeded benchmark batch
# BENCH_GAS_SAMPLES=10   # leaves used for (free, non-destructive) estimateGas
# BENCH_REAL_TXS=3       # real verifyAndBurn txs per network (burns fresh leaves)
# PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs   # optional gateway override
