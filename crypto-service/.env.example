# Copy this to .env and fill in your Pinata credentials
# Get them free at: https://app.pinata.cloud/keys

PINATA_API_KEY=your_pinata_api_key_here
PINATA_API_SECRET=your_pinata_api_secret_here

# Sepolia (L1) deployed contract addresses (from the deploy script output)
GOVERNMENT_REGISTRY_ADDRESS=
MANUFACTURER_BATCH_ADDRESS=
SUPPLY_CHAIN_TRACKER_ADDRESS=
# Sepolia (L1) RPC endpoint (Infura/Alchemy/etc.)
RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# Manufacturer wallet = your MetaMask Account 4 private key.
# This wallet signs registerBatch + verifyAndBurn, so it MUST be the address
# registered with the Manufacturer role (role 1) via setupRegistry.js.
MANUFACTURER_PRIVATE_KEY=

# Base URL for QR tracking links
APP_BASE_URL=http://localhost:3000

# ─── Consortium governance (used by setupRegistry.js) ───────────────────────
# All THREE MetaMask accounts (1, 2, 3) are on-chain regulators and any of them
# can propose or vote. The threshold is 2-of-3, so only 2 approvals are needed
# to pass: Regulator 1 proposes + auto-votes (1), Regulator 2 votes YES (2) ->
# auto-executes. Account 3 stays a full regulator but isn't needed for quorum,
# so the script only needs these two keys.
REGULATOR_1_PRIVATE_KEY=   # Account 1 (proposer; can reuse GOVERNMENT_PRIVATE_KEY)
REGULATOR_2_PRIVATE_KEY=   # Account 2 (second voter, MUST differ from Reg1)
GOVERNMENT_PRIVATE_KEY=    # owner key (fallback proposer if REGULATOR_1 unset)

# Supply-chain entity wallets to register (accounts 4/5/6 in your setup).
# Roles are fixed by the script: Manufacturer / Distributor / Retailer.
MANUFACTURER_ADDRESS=
DISTRIBUTOR_ADDRESS=
RETAILER_ADDRESS=

# ─── Arbitrum (L2) — needed by the dual-network benchmark ───────────────────
ARBITRUM_RPC_URL=
ARBITRUM_GOVERNMENT_REGISTRY_ADDRESS=
ARBITRUM_MANUFACTURER_BATCH_ADDRESS=
ARBITRUM_SUPPLY_CHAIN_TRACKER_ADDRESS=

# ─── Benchmark tunables (OPTIONAL — leave unset to use defaults) ─────────────
# These are NOT required. benchmark.js falls back to the defaults shown below.
# BENCH_STRIP_COUNT=64   # leaves in the seeded benchmark batch
# BENCH_GAS_SAMPLES=10   # leaves used for (free, non-destructive) estimateGas
# BENCH_REAL_TXS=3       # real verifyAndBurn txs per network (burns fresh leaves)
# PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs   # optional gateway override
